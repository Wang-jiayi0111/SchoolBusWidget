<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="4dp"
        android:left="1dp"
        android:right="1dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A000000" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="?attr/popupPanelColor" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="?attr/colorOutlineVariant" />
        </shape>
    </item>
</layer-list>
