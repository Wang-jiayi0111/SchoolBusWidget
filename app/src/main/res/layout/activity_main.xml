<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAppSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/main_selection_placeholder"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAppNextDeparture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/main_next_placeholder"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textAppMinutesLeft"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/main_minutes_placeholder"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonAppToggleLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_toggle_location"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/buttonAppToggleDayType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/widget_toggle_day_type"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/textDepartureListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/main_departure_list_title"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDepartureList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_departure_list_placeholder"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
