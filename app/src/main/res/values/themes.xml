<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.SchoolBusWidget" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/seed_secondary</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SchoolBus.Dialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.SchoolBus.Dialog</item>
        <item name="popupTheme">@style/ThemeOverlay.SchoolBus.Popup</item>
        <item name="actionBarPopupTheme">@style/ThemeOverlay.SchoolBus.Popup</item>
        <item name="popupMenuStyle">@style/Widget.SchoolBus.PopupMenu</item>
        <item name="popupPanelColor">@color/palette_orange_popup</item>
    </style>

    <style name="Theme.SchoolBusWidget" parent="Theme.SchoolBusWidget.Orange" />

    <style name="Theme.SchoolBusWidget.Orange" parent="Base.Theme.SchoolBusWidget">
        <item name="colorPrimary">@color/palette_orange_primary</item>
        <item name="colorPrimaryContainer">@color/palette_orange_container</item>
        <item name="colorSurface">@color/palette_orange_surface</item>
        <item name="colorSurfaceContainerLow">@color/palette_orange_card</item>
        <item name="colorSurfaceContainerHigh">@color/palette_orange_card</item>
        <item name="colorOutlineVariant">@color/palette_orange_outline</item>
        <item name="popupPanelColor">@color/palette_orange_popup</item>
    </style>

    <style name="Theme.SchoolBusWidget.Blue" parent="Base.Theme.SchoolBusWidget">
        <item name="colorPrimary">@color/palette_blue_primary</item>
        <item name="colorPrimaryContainer">@color/palette_blue_container</item>
        <item name="colorSurface">@color/palette_blue_surface</item>
        <item name="colorSurfaceContainerLow">@color/palette_blue_card</item>
        <item name="colorSurfaceContainerHigh">@color/palette_blue_card</item>
        <item name="colorOutlineVariant">@color/palette_blue_outline</item>
        <item name="popupPanelColor">@color/palette_blue_popup</item>
    </style>

    <style name="Theme.SchoolBusWidget.Green" parent="Base.Theme.SchoolBusWidget">
        <item name="colorPrimary">@color/palette_green_primary</item>
        <item name="colorPrimaryContainer">@color/palette_green_container</item>
        <item name="colorSurface">@color/palette_green_surface</item>
        <item name="colorSurfaceContainerLow">@color/palette_green_card</item>
        <item name="colorSurfaceContainerHigh">@color/palette_green_card</item>
        <item name="colorOutlineVariant">@color/palette_green_outline</item>
        <item name="popupPanelColor">@color/palette_green_popup</item>
    </style>

    <style name="Theme.SchoolBusWidget.Purple" parent="Base.Theme.SchoolBusWidget">
        <item name="colorPrimary">@color/palette_purple_primary</item>
        <item name="colorPrimaryContainer">@color/palette_purple_container</item>
        <item name="colorSurface">@color/palette_purple_surface</item>
        <item name="colorSurfaceContainerLow">@color/palette_purple_card</item>
        <item name="colorSurfaceContainerHigh">@color/palette_purple_card</item>
        <item name="colorOutlineVariant">@color/palette_purple_outline</item>
        <item name="popupPanelColor">@color/palette_purple_popup</item>
    </style>

    <style name="Theme.SchoolBusWidget.Teal" parent="Base.Theme.SchoolBusWidget">
        <item name="colorPrimary">@color/palette_teal_primary</item>
        <item name="colorPrimaryContainer">@color/palette_teal_container</item>
        <item name="colorSurface">@color/palette_teal_surface</item>
        <item name="colorSurfaceContainerLow">@color/palette_teal_card</item>
        <item name="colorSurfaceContainerHigh">@color/palette_teal_card</item>
        <item name="colorOutlineVariant">@color/palette_teal_outline</item>
        <item name="popupPanelColor">@color/palette_teal_popup</item>
    </style>

    <style name="ThemeOverlay.SchoolBus.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurfaceContainerHigh">?attr/colorSurfaceContainerLow</item>
        <item name="android:colorBackground">?attr/colorSurfaceContainerLow</item>
    </style>

    <style name="ThemeOverlay.SchoolBus.Popup" parent="ThemeOverlay.Material3.Light">
        <item name="popupPanelColor">?attr/popupPanelColor</item>
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="popupMenuBackground">@drawable/bg_popup_menu</item>
    </style>

    <style name="Widget.SchoolBus.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Widget.SchoolBus.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
        <item name="cardCornerRadius">@dimen/card_corner</item>
        <item name="cardElevation">4dp</item>
        <item name="cardMaxElevation">6dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
    </style>

    <style name="Widget.SchoolBus.ExtendedFab" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="iconTint">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.SchoolBus.ScheduleChoiceButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@color/chip_schedule_bg</item>
        <item name="android:textColor">@color/chip_schedule_text</item>
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.SchoolBus.ThemeChoiceButton" parent="Widget.Material3.Button">
        <item name="strokeWidth">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
